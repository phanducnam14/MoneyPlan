# Server Configuration
PORT=3000
NODE_ENV=development

# Database (MongoDB)
MONGODB_URI=mongodb+srv://<username>:<password>@cluster.mongodb.net/smart_finance

# JWT Authentication
JWT_SECRET=your_super_secret_jwt_key_here_replace_with_random_string

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000

# Production
# FRONTEND_URL=https://your-firebaseapp.web.app